      "adventureworks"."main"."fct_customers__dbt_tmp"
  
    as (
      

SELECT 
    c.customer_id,
    c.first_name,
    c.last_name,
    c.email,
    COUNT(DISTINCT o.order_id) AS order_count,
    COALESCE(SUM(o.total), 0) AS lifetime_value
FROM "adventureworks"."main"."stg_customers" c
LEFT JOIN "adventureworks"."main"."stg_orders" o ON c.customer_id = o.customer_id
GROUP BY c.customer_id, c.first_name, c.last_name, c.email
    );
  
  

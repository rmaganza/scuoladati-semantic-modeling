ge": null, "failures": null, "unique_id": "model.adventureworks.stg_order_lines", "compiled": true, "compiled_code": "\n\nSELECT \n    ol.order_line_id,\n    ol.order_id,\n    ol.product_id,\n    ol.quantity,\n    ol.unit_price,\n    ol.line_total,\n    ol.discount_pct,\n    -- Calcolo revenue NETTO (dopo sconto)\n    ol.line_total * (1 - ol.discount_pct) AS net_revenue,\n    p.name AS product_name,\n    p.category_id,\n    p.subcategory_id,\n    pc.name AS category_name,\n    pc.subcategory_name\nFROM \"adventureworks\".\"main\".\"order_lines\" ol\nLEFT JOIN \"adventureworks\".\"main\".\"products\" p ON ol.product_id = p.product_id\nLEFT JOIN \"adventureworks\".\"main\".\"categories\" pc ON p.subcategory_id = pc.subcategory_id", "relation_name": "\"adventureworks\".\"main\".\"stg_order_lines\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-18T17:01:24.545747Z", "completed_at": "2026-03-18T17:01:24.560514Z"}, {"name": "execute", "started_at": "2026-03-18T17:01:24.562795Z", "completed_at": "2026-03-18T17:01:24.562802Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.01801609992980957, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.adventureworks.stg_categories", "compiled": true, "compiled_code": "\n\nSELECT \n    subcategory_id,\n    category_id,\n    subcategory_name,\n    name AS category_name\nFROM \"adventureworks\".\"main\".\"categories\"", "relation_name": "\"adventureworks\".\"main\".\"stg_categories\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-18T17:01:24.563432Z", "completed_at": "2026-03-18T17:01:24.571601Z"}, {"name": "execute", "started_at": "2026-03-18T17:01:24.572034Z", "completed_at": "2026-03-18T17:01:24.572043Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.010084867477416992, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.adventureworks.stg_products", "compiled": true, "compiled_code": "\n\nSELECT \n    product_id,\n    name,\n    category_id,\n    subcategory_id,\n    price\nFROM \"adventureworks\".\"main\".\"products\"", "relation_name": "\"adventureworks\".\"main\".\"stg_products\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-18T17:01:24.567837Z", "completed_at": "2026-03-18T17:01:24.572827Z"}, {"name": "execute", "started_at": "2026-03-18T17:01:24.573351Z", "completed_at": "2026-03-18T17:01:24.573361Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.013395071029663086, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.adventureworks.stg_orders", "compiled": true, "compiled_code": "\n\nSELECT \n    o.order_id,\n    o.customer_id,\n    o.order_date,\n    o.total,\n    o.status,\n    c.city\nFROM \"adventureworks\".\"main\".\"orders\" o\nLEFT JOIN \"adventureworks\".\"main\".\"customers\" c ON o.customer_id = c.customer_id", "relation_name": "\"adventureworks\".\"main\".\"stg_orders\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-18T17:01:24.575191Z", "completed_at": "2026-03-18T17:01:24.578965Z"}, {"name": "execute", "started_at": "2026-03-18T17:01:24.579455Z", "completed_at": "2026-03-18T17:01:24.579465Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005083560943603516, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.adventureworks.fct_products", "compiled": true, "compiled_code": "\n\nSELECT \n    p.product_id,\n    p.name AS product_name,\n    p.category_id,\n    p.subcategory_id,\n    pc.category_name AS category_name,\n    pc.subcategory_name,\n    COUNT(DISTINCT ol.order_id) AS orders_with_product,\n    COALESCE(SUM(ol.quantity), 0) AS units_sold,\n    COALESCE(SUM(ol.line_total), 0) AS gross_revenue,\n    COALESCE(SUM(ol.net_revenue), 0) AS net_revenue\nFROM \"adventureworks\".\"main\".\"stg_products\" p\nLEFT JOIN \"adventureworks\".\"main\".\"stg_order_lines\" ol ON p.product_id = ol.product_id\nLEFT JOIN \"adventureworks\".\"main\".\"stg_categories\" pc ON p.subcategory_id = pc.subcategory_id\nGROUP BY p.product_id, p.name, p.category_id, p.subcategory_id, pc.category_name, pc.subcategory_name", "relation_name": "\"adventureworks\".\"main\".\"fct_products\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-18T17:01:24.582713Z", "completed_at": "2026-03-18T17:01:24.591507Z"}, {"name": "execute", "started_at": "2026-03-18T17:01:24.592120Z", "completed_at": "2026-03-18T17:01:24.592135Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.01127004623413086, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.adventureworks.fct_customers", "compiled": true, "compiled_code": "\n\nSELECT \n    c.customer_id,\n    c.first_name,\n    c.last_name,\n    c.email,\n    c.city,\n    COUNT(DISTINCT o.order_id) AS order_count,\n    COALESCE(SUM(o.total), 0) AS lifetime_value,\n    COALESCE(SUM(ol.net_revenue), 0) AS lifetime_net_revenue\nFROM \"adventureworks\".\"main\".\"stg_customers\" c\nLEFT JOIN \"adventureworks\".\"main\".\"stg_orders\" o ON c.customer_id = o.customer_id AND o.status = 5\nLEFT JOIN \"adventureworks\".\"main\".\"stg_order_lines\" ol ON o.order_id = ol.order_id\nGROUP BY c.customer_id, c.first_name, c.last_name, c.email, c.city", "relation_name": "\"adventureworks\".\"main\".\"fct_customers\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-18T17:01:24.586759Z", "completed_at": "2026-03-18T17:01:24.592958Z"}, {"name": "execute", "started_at": "2026-03-18T17:01:24.593953Z", "completed_at": "2026-03-18T17:01:24.593963Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.012652158737182617, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.adventureworks.fct_orders", "compiled": true, "compiled_code": "\n\nSELECT \n    o.order_id,\n    o.order_date,\n    o.customer_id,\n    c.first_name || ' ' || c.last_name AS customer_name,\n    c.city,\n    o.status,\n    o.total AS order_total,\n    COUNT(ol.order_line_id) AS line_count,\n    SUM(ol.quantity) AS total_items,\n    COALESCE(SUM(ol.line_total), 0) AS gross_revenue,\n    COALESCE(SUM(ol.net_revenue), 0) AS net_revenue\nFROM \"adventureworks\".\"main\".\"stg_orders\" o\nLEFT JOIN \"adventureworks\".\"main\".\"stg_order_lines\" ol ON o.order_id = ol.order_id\nLEFT JOIN \"adventureworks\".\"main\".\"stg_customers\" c ON o.customer_id = c.customer_id\nWHERE o.status = 5  -- Solo ordini spediti\nGROUP BY o.order_id, o.order_date, o.customer_id, c.first_name, c.last_name, c.city, o.status, o.total", "relation_name": "\"adventureworks\".\"main\".\"fct_orders\"", "batch_results": null}], "elapsed_time": 0.2023310661315918, "args": {"static_parser": true, "introspect": true, "populate_cache": true, "source_freshness_run_project_hooks": true, "use_colors": true, "quiet": false, "require_batched_execution_for_custom_microbatch_strategy": false, "require_nested_cumulative_type_params": false, "require_ref_searches_node_package_before_root": false, "show_all_deprecations": false, "cache_selected_only": false, "require_yaml_configuration_for_mf_time_spines": false, "state_modified_compare_more_unrendered_values": false, "state_modified_compare_vars": false, "use_colors_file": true, "favor_state": false, "partial_parse": true, "use_fast_test_edges": false, "write_json": true, "log_file_max_bytes": 10485760, "require_resource_names_without_spaces": true, "send_anonymous_usage_stats": true, "vars": {}, "which": "generate", "require_explicit_package_overrides_for_builtin_materializations": true, "static": false, "empty_catalog": false, "project_dir": "/home/workspace/adventureworks-dbt-course/adventureworks", "macro_debugging": false, "skip_nodes_if_on_run_start_fails": false, "invocation_command": "dbt docs generate", "log_format_f